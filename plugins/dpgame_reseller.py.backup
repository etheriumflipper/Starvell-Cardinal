# === CALLBACK ОБРАБОТЧИКИ ===
CALLBACKS = {
    "dp_callbacks": {
        "handler": handle_dp_callbacks,
        "filter": F.data.startswith("dp:")
    }
}

# === TEXT HANDLERS ===
TEXT_HANDLERS = {
    "mass_add_handler": {
        "handler": handle_mass_add_input,
        "filter": lambda m: m.from_user.id in _mass_add_states
    },
    "api_key_handler": {
