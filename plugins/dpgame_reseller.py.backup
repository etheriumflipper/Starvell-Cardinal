def ensure_storage():
    """Создать директорию если не существует"""
    STORAGE_DIR.mkdir(parents=True, exist_ok=True)


def load_json(filepath: Path, default=None):
    """Загрузить JSON файл"""
    if default is None:
        default = {}

    if filepath.exists():
        try:
            with open(filepath, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка загрузки {filepath}: {e}")

    return default


def save_json(filepath: Path, data):
    """Сохранить JSON файл"""
    ensure_storage()
    try:
        with open(filepath, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=4, ensure_ascii=False)
    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка сохранения {filepath}: {e}")


# Блокировки для потокобезопасности
_file_locks = {
    "settings": threading.Lock(),
    "bindings": threading.Lock(),
    "orders": threading.Lock(),
    "order_log": threading.Lock(),
    "templates": threading.Lock(),
    "cache": threading.Lock()
}


class DPGameAPI:
    """Клиент для работы с DPGame API"""

    def __init__(self, api_key: str):
        self.api_key = api_key
        self.headers = {"X-API-Key": api_key}
        self._token_cache = {}  # Кеш токенов
        self._rate_cache = {}  # Кеш курсов валют

    def _is_cache_valid(self, cache_key: str, ttl_minutes: int = 30) -> bool:
        """Проверить валидность кеша"""
        if cache_key not in self._token_cache:
            return False

        cached_time = self._token_cache[cache_key].get("timestamp", 0)
        return (time.time() - cached_time) < (ttl_minutes * 60)

    def _set_cache(self, cache_key: str, value):
        """Установить значение в кеш"""
        self._token_cache[cache_key] = {
            "value": value,
            "timestamp": time.time()
        }

    def _get_cache(self, cache_key: str):
        """Получить значение из кеша"""
        return self._token_cache.get(cache_key, {}).get("value")

    async def get_profile(self) -> Optional[Dict]:
        """Получить профиль пользователя"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(
                    f"{DPGAME_API_URL}/profile/me",
                    headers=self.headers
                ) as response:
                    response.raise_for_status()
                    data = await response.json()
                    return data.get("user")
        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка получения профиля: {e}")
            return None

    async def get_position(self, position_id: int) -> Optional[Dict]:
        """Получить информацию о позиции"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(
                    f"{DPGAME_API_URL}/store/positions/{position_id}",
                    headers=self.headers
                ) as response:
                    response.raise_for_status()
                    data = await response.json()
                    return data.get("position")
        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка получения позиции {position_id}: {e}")
            return None

    async def get_currency_rate(self, from_currency: str = "USD", to_currency: str = "RUB") -> float:
        """Получить курс валюты с кешированием"""
        cache_key = f"rate_{from_currency}_{to_currency}"

        # Проверяем кеш
        if self._is_cache_valid(cache_key, ttl_minutes=30):
            cached_rate = self._get_cache(cache_key)
            if cached_rate:
                return cached_rate

        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(
                    f"{DPGAME_API_URL}/steam/rate/{from_currency}:{to_currency}",
                    headers=self.headers
                ) as response:
                    response.raise_for_status()
                    data = await response.json()
                    rate = float(data.get("rate", 92.0))

                    # Сохраняем в кеш
                    self._set_cache(cache_key, rate)
                    return rate
        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка получения курса валюты: {e}")
            # Возвращаем из кеша если есть, иначе дефолт
            cached_rate = self._get_cache(cache_key)
            return cached_rate if cached_rate else 92.0

    async def purchase_position(self, position_id: int, quantity: int = 1) -> Optional[Dict]:
        """Купить позицию"""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(
                    f"{DPGAME_API_URL}/store/positions/purchase",
                    headers=self.headers,
                    json={"position_id": position_id, "quantity": quantity}
                ) as response:
                    if response.status == 400:
                        # Недостаточно товара
                        error_data = await response.json()
                        logger.warning(f"{LOGGER_PREFIX} Недостаточно товара: {error_data}")
                        return {"error": "insufficient_products", "detail": error_data.get("detail")}
                    elif response.status == 403:
                        # Недостаточно баланса
                        error_data = await response.json()
                        logger.warning(f"{LOGGER_PREFIX} Недостаточно баланса: {error_data}")
                        return {"error": "insufficient_balance", "detail": error_data.get("detail")}

                    response.raise_for_status()
                    data = await response.json()
                    return data.get("purchase")
        except aiohttp.ClientError as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка покупки позиции {position_id}: {e}")
            return {"error": "api_error", "detail": str(e)}
        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Неожиданная ошибка при покупке: {e}")
            return {"error": "unknown", "detail": str(e)}


class DPGameReseller:
    """Основной класс плагина"""

    def __init__(self):
        self.settings = load_json(SETTINGS_FILE, DEFAULT_SETTINGS)
        self.bindings = load_json(BINDINGS_FILE, {})  # {starvell_lot_id: dpgame_position_id}
        self.templates = load_json(TEMPLATES_FILE, DEFAULT_TEMPLATES)
        self.active_orders = {}  # {order_id: order_info}
        self.api = DPGameAPI(self.settings.get("api_key", ""))
        self._retry_tasks = {}  # {order_id: asyncio.Task}
        self._check_thread = None  # Поток для периодических проверок
        self._stop_check_thread = False

    def save_bindings(self):
        """Сохранить привязки"""
        with _file_locks["bindings"]:
            save_json(BINDINGS_FILE, self.bindings)

    def save_settings(self):
        """Сохранить настройки"""
        with _file_locks["settings"]:
            save_json(SETTINGS_FILE, self.settings)

    def save_templates(self):
        """Сохранить шаблоны"""
        with _file_locks["templates"]:
            save_json(TEMPLATES_FILE, self.templates)

    def log_order_to_json(self, order_id: str, supplier: str, sales_price: float, purchase_cost: float, profit: float):
        """Логировать заказ в статистику"""
        with _file_locks["order_log"]:
            order_log = load_json(ORDER_LOG_FILE, [])

            order_entry = {
                "order_id": order_id,
                "supplier": supplier,
                "sales_price": sales_price,
                "purchase_cost": purchase_cost,
                "profit": profit,
                "timestamp": datetime.now().isoformat()
            }

            order_log.append(order_entry)
            save_json(ORDER_LOG_FILE, order_log)

            logger.info(f"{LOGGER_PREFIX} Заказ {order_id} записан в статистику: прибыль {profit:.2f}₽")

    def get_stats(self) -> Dict:
        """Получить статистику продаж"""
        with _file_locks["order_log"]:
            order_log = load_json(ORDER_LOG_FILE, [])

        total_orders = len(order_log)
        total_sales = sum(entry.get("sales_price", 0) for entry in order_log)
        total_costs = sum(entry.get("purchase_cost", 0) for entry in order_log)
        total_profit = sum(entry.get("profit", 0) for entry in order_log)

        return {
            "total_orders": total_orders,
            "total_sales": total_sales,
            "total_costs": total_costs,
            "total_profit": total_profit,
            "avg_profit": total_profit / total_orders if total_orders > 0 else 0
        }

    def get_dpgame_position_id(self, starvell_offer_id: str) -> Optional[int]:
        """Получить DPGame position_id по Starvell offer_id из привязок"""
        return self.bindings.get(str(starvell_offer_id))

    def extract_offer_id_from_url(self, url: str) -> Optional[str]:
        """Извлечь offer_id из URL Starvell"""
        import re
        # https://starvell.com/offers/207715 -> 207715
        match = re.search(r'/offers/(\d+)', url)
        if match:
            return match.group(1)
        return None

    async def handle_new_order(self, order_data: dict, starvell_service=None, **kwargs):
        """Обработчик нового заказа"""
        try:
            if not starvell_service:
                return

            order_id = order_data.get("id")
            chat_id = order_data.get("chat_id")

            if not chat_id:
                logger.warning(f"{LOGGER_PREFIX} Заказ {order_id} без chat_id, получаю из деталей...")
                # Получаем детали заказа для chat_id
                try:
                    details = await starvell_service.get_order_details(order_id)
                    page_props = details.get("pageProps", {})
                    chat_data = page_props.get("chat", {})
                    chat_id = chat_data.get("id")

                    if not chat_id:
                        logger.error(f"{LOGGER_PREFIX} Не удалось получить chat_id для заказа {order_id}")
                        return
                except Exception as e:
                    logger.error(f"{LOGGER_PREFIX} Ошибка получения деталей заказа: {e}")
                    return

            # Получаем полные детали заказа для offerId и quantity
            try:
                details = await starvell_service.get_order_details(order_id)
                page_props = details.get("pageProps", {})
                order_details = page_props.get("order", {})

                starvell_offer_id = order_details.get("offerId")
                quantity = order_details.get("quantity", 1)

                if not starvell_offer_id:
                    logger.debug(f"{LOGGER_PREFIX} Заказ {order_id} без offerId")
                    return

            except Exception as e:
                logger.error(f"{LOGGER_PREFIX} Ошибка получения offerId: {e}")
                return

            # Ищем привязку
            dpgame_position_id = self.get_dpgame_position_id(str(starvell_offer_id))

            if not dpgame_position_id:
                logger.debug(f"{LOGGER_PREFIX} Для лота {starvell_offer_id} нет привязки к DPGame")
                return

            logger.info(f"{LOGGER_PREFIX} Новый заказ {order_id} для DPGame позиции {dpgame_position_id}, количество: {quantity}")

            # Сохраняем информацию о заказе
            self.active_orders[order_id] = {
                "dpgame_position_id": dpgame_position_id,
                "chat_id": chat_id,
                "buyer": order_data.get("buyer"),
                "amount": order_data.get("amount"),
                "lot_name": order_data.get("lot_name"),
                "quantity": quantity,
                "created_at": datetime.now().isoformat(),
                "retry_count": 0
            }

            # Отправляем уведомление о начале обработки
            template = self.templates.get("processing", DEFAULT_TEMPLATES["processing"])
            await starvell_service.send_message(chat_id, template)

            # Запускаем процесс покупки
            await self.process_order(order_id, starvell_service)

        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка обработки заказа: {e}", exc_info=True)

    async def process_order(self, order_id: str, starvell_service):
        """Обработка заказа с retry логикой"""
        order_info = self.active_orders.get(order_id)
        if not order_info:
            return

        dpgame_position_id = order_info["dpgame_position_id"]
        chat_id = order_info["chat_id"]
        quantity = order_info.get("quantity", 1)
        max_retry_time = timedelta(minutes=self.settings["max_retry_minutes"])
        start_time = datetime.now()

        # Тестовый режим
        if self.settings.get("test_mode", False):
            logger.info(f"{LOGGER_PREFIX} [TEST MODE] Симуляция покупки для заказа {order_id}")
            await asyncio.sleep(2)  # Имитация задержки

            # Генерируем тестовые коды
            test_products = [f"TEST-CODE-{i+1}-XXXX-YYYY-ZZZZ" for i in range(quantity)]
            await self.deliver_products(order_id, test_products, starvell_service)
            return

        while True:
            try:
                # Попытка покупки с учётом количества
                logger.info(f"{LOGGER_PREFIX} Попытка покупки позиции {dpgame_position_id} (x{quantity}) для заказа {order_id}")
                purchase_result = await self.api.purchase_position(
                    dpgame_position_id,
                    quantity=quantity
                )

                if not purchase_result:
                    # API не ответил
                    logger.warning(f"{LOGGER_PREFIX} API не ответил для заказа {order_id}")

                    # Проверяем время
                    if datetime.now() - start_time > max_retry_time:
                        await self.refund_order(order_id, starvell_service, "API не отвечает более 15 минут")
                        return

                    # Ждём и повторяем
                    await asyncio.sleep(self.settings["retry_interval"])
                    order_info["retry_count"] += 1
                    continue

                # Проверяем ошибки
                if "error" in purchase_result:
                    error_type = purchase_result["error"]

                    if error_type == "insufficient_balance":
                        # Недостаточно баланса - возврат
                        await self.refund_order(order_id, starvell_service, "Недостаточно средств на балансе DPGame")
                        return

                    elif error_type == "insufficient_products":
                        # Товара нет - возврат
                        await self.refund_order(order_id, starvell_service, "Товар закончился на складе")
                        return

                    else:
                        # Другая ошибка - retry
                        logger.warning(f"{LOGGER_PREFIX} Ошибка API: {error_type}")

                        if datetime.now() - start_time > max_retry_time:
                            await self.refund_order(order_id, starvell_service, f"Ошибка покупки: {purchase_result.get('detail')}")
                            return

                        await asyncio.sleep(self.settings["retry_interval"])
                        order_info["retry_count"] += 1
                        continue

                # Успешная покупка!
                products = purchase_result.get("products", [])
                await self.deliver_products(order_id, products, starvell_service)
                return

            except Exception as e:
                logger.error(f"{LOGGER_PREFIX} Ошибка в process_order: {e}", exc_info=True)

                if datetime.now() - start_time > max_retry_time:
                    await self.refund_order(order_id, starvell_service, f"Критическая ошибка: {str(e)}")
                    return

                await asyncio.sleep(self.settings["retry_interval"])
                order_info["retry_count"] += 1

    async def deliver_products(self, order_id: str, products: list, starvell_service):
        """Отправить товары покупателю"""
        order_info = self.active_orders.get(order_id)
        if not order_info:
            return

        chat_id = order_info["chat_id"]
        lot_name = order_info["lot_name"]
        sales_price = order_info.get("amount", 0)

        # Форматируем товары
        products_text = "\n".join([f"🔑 `{product}`" for product in products])

        # Используем шаблон
        template = self.templates.get("delivery", DEFAULT_TEMPLATES["delivery"])
        message = template.format(
            lot_name=lot_name,
            quantity=len(products),
            products=products_text,
            order_id=order_id
        )

        try:
            await starvell_service.send_message(chat_id, message)
            logger.info(f"{LOGGER_PREFIX} Товары доставлены для заказа {order_id}")

            # Логируем статистику
            dpgame_position_id = order_info["dpgame_position_id"]
            position = await self.api.get_position(dpgame_position_id)
            if position:
                dpgame_price_usd = position.get("price", 0)
                usd_to_rub = await self.api.get_currency_rate("USD", "RUB")
                purchase_cost = dpgame_price_usd * usd_to_rub * len(products)

                # Учитываем комиссию вывода
                withdrawal_fee = self.settings.get("withdrawal_fee_percent", 0)
                net_sales_price = sales_price * (1 - withdrawal_fee / 100)

                profit = net_sales_price - purchase_cost

                self.log_order_to_json(
                    order_id=order_id,
                    supplier="DPGame",
                    sales_price=sales_price,
                    purchase_cost=purchase_cost,
                    profit=profit
                )

            # Удаляем заказ из активных
            del self.active_orders[order_id]

        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка отправки товаров: {e}")

    async def refund_order(self, order_id: str, starvell_service, reason: str):
        """Возврат средств за заказ"""
        order_info = self.active_orders.get(order_id)
        if not order_info:
            return

        chat_id = order_info["chat_id"]

        # Используем шаблон
        template = self.templates.get("refund", DEFAULT_TEMPLATES["refund"])
        message = template.format(reason=reason)

        try:
            await starvell_service.send_message(chat_id, message)

            # Возврат через Starvell API
            await starvell_service.refund_order(order_id)

            logger.info(f"{LOGGER_PREFIX} Возврат выполнен для заказа {order_id}: {reason}")

            # Удаляем заказ из активных
            del self.active_orders[order_id]

        except Exception as e:
            logger.error(f"{LOGGER_PREFIX} Ошибка возврата средств: {e}")

    def start_periodic_check(self):
        """Запустить поток периодической проверки товаров"""
        if self._check_thread and self._check_thread.is_alive():
            return

        self._stop_check_thread = False
        self._check_thread = threading.Thread(target=self._periodic_check_loop, daemon=True)
        self._check_thread.start()
        logger.info(f"{LOGGER_PREFIX} Поток периодической проверки запущен")

    def stop_periodic_check(self):
        """Остановить поток периодической проверки"""
        self._stop_check_thread = True
        if self._check_thread:
            self._check_thread.join(timeout=5)
        logger.info(f"{LOGGER_PREFIX} Поток периодической проверки остановлен")

    def _periodic_check_loop(self):
        """Цикл периодической проверки товаров"""
        check_interval = self.settings.get("check_interval_hours", 2) * 3600

        while not self._stop_check_thread:
            try:
                logger.info(f"{LOGGER_PREFIX} Запуск периодической проверки товаров...")

                # Проверяем каждую привязку
                for starvell_offer_id, dpgame_position_id in self.bindings.items():
                    if self._stop_check_thread:
                        break

                    # Используем синхронный запрос через asyncio
                    loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(loop)

                    try:
                        position = loop.run_until_complete(self.api.get_position(dpgame_position_id))

                        if position:
                            products_available = position.get("products_available", 0)
                            position_name = position.get("name", "Неизвестно")

                            if products_available == 0:
                                logger.warning(
                                    f"{LOGGER_PREFIX} Товар закончился: {position_name} "
                                    f"(DPGame ID: {dpgame_position_id}, Starvell ID: {starvell_offer_id})"
                                )
                            elif products_available < 10:
                                logger.warning(
                                    f"{LOGGER_PREFIX} Мало товара: {position_name} "
                                    f"(осталось {products_available} шт., DPGame ID: {dpgame_position_id})"
                                )
                    finally:
                        loop.close()

                    time.sleep(1)  # Задержка между проверками

                logger.info(f"{LOGGER_PREFIX} Периодическая проверка завершена")

            except Exception as e:
                logger.error(f"{LOGGER_PREFIX} Ошибка в периодической проверке: {e}", exc_info=True)

            # Ждём до следующей проверки
            for _ in range(int(check_interval)):
                if self._stop_check_thread:
                    break
                time.sleep(1)


# === Глобальный экземпляр ===
_reseller_instance: Optional[DPGameReseller] = None


def on_pre_init():
    """Инициализация перед запуском бота"""
    ensure_storage()
    logger.info(f"{LOGGER_PREFIX} {NAME} v{VERSION} загружен")


async def on_init(bot=None, starvell=None, db=None, plugin_manager=None):
    """Инициализация после запуска бота"""
    global _reseller_instance
    _reseller_instance = DPGameReseller()

    # Проверяем API ключ
    if not _reseller_instance.settings.get("api_key"):
        logger.warning(f"{LOGGER_PREFIX} API ключ не настроен! Установите api_key в {SETTINGS_FILE}")
    else:
        # Проверяем подключение
        profile = await _reseller_instance.api.get_profile()
        if profile:
            balance = profile.get("balance", "0")
            logger.info(f"{LOGGER_PREFIX} Подключено к DPGame. Баланс: ${balance}")
        else:
            logger.error(f"{LOGGER_PREFIX} Не удалось подключиться к DPGame API")

    # Запускаем периодическую проверку товаров
    if _reseller_instance.settings.get("check_interval_hours", 0) > 0:
        _reseller_instance.start_periodic_check()

    logger.info(f"{LOGGER_PREFIX} Плагин инициализирован")


async def on_new_order(order_data: dict, starvell_service=None, **kwargs):
    """Обработчик новых заказов"""
    if _reseller_instance:
        await _reseller_instance.handle_new_order(order_data, starvell_service, **kwargs)


def on_delete():
    """Удаление плагина"""
    global _reseller_instance
    if _reseller_instance:
        _reseller_instance.stop_periodic_check()
    logger.info(f"{LOGGER_PREFIX} Плагин удаляется...")


# === TELEGRAM КОМАНДЫ ===
from aiogram import types, F
from aiogram.filters import Command
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton

# Глобальное хранилище состояний для массового добавления
_mass_add_states = {}  # {user_id: True}
_api_key_setup_states = {}  # {user_id: True}

async def get_starvell_offer_price(starvell_service, offer_id: str) -> Optional[float]:
    """Получить цену лота на Starvell через поиск в заказах"""
    if not starvell_service:
        return None

    try:
        # Получаем список всех заказов
        orders = await starvell_service.get_orders()

        # Ищем заказ с нужным offerId
        for order in orders:
            if str(order.get("offerId")) == str(offer_id):
                # Цена в копейках, конвертируем в рубли
                total_price = order.get("totalPrice", 0)
                return total_price / 100

        # Если не нашли в заказах, возвращаем None
        return None

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка получения цены Starvell: {e}")
        return None


async def create_binding_summary(dpgame_position_id: int, starvell_offer_id: str, position: dict, starvell_price: Optional[float] = None, usd_to_rub: float = 92.0) -> str:
    """Создать красивое описание привязки с сравнением цен"""
    position_name = position.get("name", "Неизвестно")
    dpgame_price_usd = position.get("price", 0)
    products_available = position.get("products_available", 0)

    # Конвертируем USD в RUB
    dpgame_price_rub = dpgame_price_usd * usd_to_rub

    summary = (
        "📋 **Информация о привязке:**\n\n"
        f"📦 **Товар:** {position_name}\n"
        f"🆔 **Starvell Offer ID:** `{starvell_offer_id}`\n"
        f"🎮 **DPGame Position ID:** `{dpgame_position_id}`\n"
        f"📊 **В наличии:** {products_available} шт.\n\n"
        f"💰 **Цена DPGame:** ${dpgame_price_usd:.2f} (~{dpgame_price_rub:.2f}₽)\n"
    )

    if starvell_price:
        profit = starvell_price - dpgame_price_rub
        profit_percent = (profit / dpgame_price_rub * 100) if dpgame_price_rub > 0 else 0

        summary += (
            f"💵 **Цена Starvell:** {starvell_price:.2f}₽\n"
            f"📈 **Прибыль:** {profit:.2f}₽ ({profit_percent:+.1f}%)\n"
        )

        if profit < 0:
            summary += "\n⚠️ **Внимание:** Цена на Starvell ниже закупочной!"
        elif profit_percent < 10:
            summary += "\n⚠️ **Внимание:** Низкая наценка (менее 10%)"

    return summary


async def cmd_dp_bind(message: types.Message):
    """Команда для привязки DPGame товара к Starvell лоту
    Использование: /dp_bind <dpgame_position_id> <starvell_offer_url_or_id>
    Пример: /dp_bind 123 https://starvell.com/offers/207715
    Пример: /dp_bind 123 207715
    """
    global _reseller_instance

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    try:
        # Парсим аргументы
        args = message.text.split()[1:]  # Убираем /dp_bind

        if len(args) != 2:
            await message.answer(
                "❌ **Неверный формат команды**\n\n"
                "📝 **Использование:**\n"
                "`/dp_bind <dpgame_id> <starvell_offer>`\n\n"
                "**Примеры:**\n"
                "`/dp_bind 123 https://starvell.com/offers/207715`\n"
                "`/dp_bind 123 207715`"
            )
            return

        dpgame_position_id = args[0]
        starvell_input = args[1]

        # Проверяем что dpgame_position_id это число
        try:
            dpgame_position_id = int(dpgame_position_id)
        except ValueError:
            await message.answer("❌ DPGame ID должен быть числом", parse_mode="Markdown")
            return

        # Извлекаем offer_id из URL или используем как есть
        if "starvell.com" in starvell_input or "https://" in starvell_input:
            starvell_offer_id = _reseller_instance.extract_offer_id_from_url(starvell_input)
            if not starvell_offer_id:
                await message.answer("❌ Не удалось извлечь ID лота из URL", parse_mode="Markdown")
                return
        else:
            starvell_offer_id = starvell_input

        # Проверяем существование позиции на DPGame
        status_msg = await message.answer("🔍 Проверяю товар на DPGame...", parse_mode="Markdown")
        position = await _reseller_instance.api.get_position(dpgame_position_id)

        if not position:
            await status_msg.edit_text(
                f"❌ **Товар не найден на DPGame**\n\n"
                f"DPGame ID: `{dpgame_position_id}`\n"
                f"Проверьте правильность ID"
            )
            return

        # Сохраняем привязку
        _reseller_instance.bindings[str(starvell_offer_id)] = dpgame_position_id
        _reseller_instance.save_bindings()

        # Получаем курс валюты
        usd_to_rub = await _reseller_instance.api.get_currency_rate("USD", "RUB")

        # Получаем цену на Starvell (если доступно)
        starvell_price = await get_starvell_offer_price(None, starvell_offer_id)

        # Создаём красивое описание
        summary = await create_binding_summary(dpgame_position_id, starvell_offer_id, position, starvell_price, usd_to_rub)

        await status_msg.edit_text("✅ **Привязка создана успешно!**")
        await message.answer(summary, parse_mode="Markdown")

        logger.info(f"{LOGGER_PREFIX} Создана привязка: Starvell {starvell_offer_id} -> DPGame {dpgame_position_id}")

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в cmd_dp_bind: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def cmd_dp_any(message: types.Message):
    """Команда для массового добавления привязок
    Использование: /dp_any
    После команды отправляйте строки в формате: dpgame_id starvell_offer_id
    """
    global _reseller_instance, _mass_add_states

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    user_id = message.from_user.id
    _mass_add_states[user_id] = True

    await message.answer(
        "📝 **Режим массового добавления активирован**\n\n"
        "Отправляйте строки в формате:\n"
        "`<dpgame_id> <starvell_offer_id>`\n\n"
        "**Пример:**\n"
        "`123 207715`\n"
        "`456 207716`\n"
        "`789 207717`\n\n"
        "Для завершения отправьте `/dp_stop`"
    )


async def cmd_dp_stop(message: types.Message):
    """Остановить режим массового добавления"""
    global _mass_add_states

    user_id = message.from_user.id

    if user_id not in _mass_add_states:
        await message.answer("❌ Режим массового добавления не активен", parse_mode="Markdown")
        return

    del _mass_add_states[user_id]
    await message.answer("✅ Режим массового добавления завершён", parse_mode="Markdown")


async def handle_mass_add_input(message: types.Message):
    """Обработчик текстовых сообщений для массового добавления"""
    global _reseller_instance, _mass_add_states

    user_id = message.from_user.id

    if user_id not in _mass_add_states:
        return

    if not _reseller_instance:
        return

    try:
        # Парсим строку: dpgame_id starvell_offer_id
        parts = message.text.strip().split()

        if len(parts) != 2:
            await message.answer("❌ Неверный формат. Используйте: `<dpgame_id> <starvell_offer_id>`", parse_mode="Markdown")
            return

        dpgame_position_id = parts[0]
        starvell_offer_id = parts[1]

        # Проверяем что dpgame_position_id это число
        try:
            dpgame_position_id = int(dpgame_position_id)
        except ValueError:
            await message.answer("❌ DPGame ID должен быть числом", parse_mode="Markdown")
            return

        # Проверяем существование позиции на DPGame
        position = await _reseller_instance.api.get_position(dpgame_position_id)

        if not position:
            await message.answer(
                f"❌ **Товар не найден**\n"
                f"DPGame ID: `{dpgame_position_id}`"
            )
            return

        # Сохраняем привязку
        _reseller_instance.bindings[str(starvell_offer_id)] = dpgame_position_id
        _reseller_instance.save_bindings()

        # Получаем курс валюты
        usd_to_rub = await _reseller_instance.api.get_currency_rate("USD", "RUB")

        # Получаем цену на Starvell (если доступно)
        starvell_price = await get_starvell_offer_price(None, starvell_offer_id)

        # Создаём красивое описание
        summary = await create_binding_summary(dpgame_position_id, starvell_offer_id, position, starvell_price, usd_to_rub)

        await message.answer("✅ **Привязка добавлена**", parse_mode="Markdown")
        await message.answer(summary, parse_mode="Markdown")

        logger.info(f"{LOGGER_PREFIX} Массовое добавление: Starvell {starvell_offer_id} -> DPGame {dpgame_position_id}")

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в handle_mass_add_input: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def handle_api_key_input(message: types.Message):
    """Обработчик ввода API ключа"""
    global _reseller_instance, _api_key_setup_states

    user_id = message.from_user.id

    if user_id not in _api_key_setup_states:
        return

    if not _reseller_instance:
        return

    try:
        api_key = message.text.strip()

        # Удаляем сообщение с ключом для безопасности
        try:
            await message.delete()
        except:
            pass

        # Проверяем ключ
        test_api = DPGameAPI(api_key)
        profile = await test_api.get_profile()

        if not profile:
            await message.answer(
                "❌ **Неверный API ключ**\n\n"
                "Не удалось подключиться к DPGame с этим ключом.\n"
                "Проверьте правильность и попробуйте снова.\n\n"
                "Для отмены отправьте `/dp_cancel`"
            )
            return

        # Сохраняем ключ
        _reseller_instance.settings["api_key"] = api_key
        _reseller_instance.save_settings()

        # Обновляем API клиент
        _reseller_instance.api = DPGameAPI(api_key)

        # Убираем состояние
        del _api_key_setup_states[user_id]

        username = profile.get("username", "Неизвестно")
        balance = profile.get("balance", "0")

        await message.answer(
            "✅ **API ключ успешно настроен!**\n\n"
            f"👤 **Аккаунт:** {username}\n"
            f"💰 **Баланс:** ${balance}\n\n"
            "Теперь вы можете использовать все функции плагина.\n"
            "Используйте `/dp_game` для доступа к меню."
        )

        logger.info(f"{LOGGER_PREFIX} API ключ настроен для пользователя {username}")

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в handle_api_key_input: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def cmd_dp_cancel(message: types.Message):
    """Отменить текущую операцию ввода"""
    global _api_key_setup_states

    user_id = message.from_user.id

    if user_id in _api_key_setup_states:
        del _api_key_setup_states[user_id]
        await message.answer("✅ Настройка API ключа отменена", parse_mode="Markdown")
    else:
        await message.answer("❌ Нет активных операций для отмены", parse_mode="Markdown")


async def cmd_dp_game(message: types.Message):
    """Главное меню DPGame плагина с балансом и статистикой"""
    global _reseller_instance

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    try:
        # Проверяем наличие API ключа
        if not _reseller_instance.settings.get("api_key"):
            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="🔑 Настроить API ключ", callback_data="dp:setup_key")]
            ])
            await message.answer(
                "⚠️ **API ключ не настроен**\n\n"
                "Для работы плагина необходимо указать API ключ от DPGame.\n\n"
                "📝 Получить ключ можно на: https://wholesale.dpgame.shop/\n"
                "👤 Профиль → API Keys → Create New Key",
                reply_markup=keyboard
            )
            return

        # Получаем профиль
        profile = await _reseller_instance.api.get_profile()

        if not profile:
            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="🔑 Изменить API ключ", callback_data="dp:setup_key")]
            ])
            await message.answer(
                "❌ **Не удалось получить данные профиля DPGame**\n\n"
                "Возможные причины:\n"
                "• Неверный API ключ\n"
                "• API ключ истёк\n"
                "• Проблемы с подключением\n\n"
                "Проверьте ключ и попробуйте снова.",
                reply_markup=keyboard
            )
            return

        username = profile.get("username", "Неизвестно")
        balance = profile.get("balance", "0")
        is_reseller = profile.get("is_reseller", False)

        # Количество привязок
        bindings_count = len(_reseller_instance.bindings)

        # Получаем статистику
        stats = _reseller_instance.get_stats()

        # Создаём клавиатуру
        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [
                InlineKeyboardButton(text="🔗 Добавить привязку", callback_data="dp:help_bind"),
                InlineKeyboardButton(text="📋 Список привязок", callback_data="dp:list")
            ],
            [
                InlineKeyboardButton(text="📝 Массовое добавление", callback_data="dp:help_mass"),
                InlineKeyboardButton(text="📊 Статистика", callback_data="dp:stats")
            ],
            [
                InlineKeyboardButton(text="⚙️ Настройки", callback_data="dp:settings"),
                InlineKeyboardButton(text="🔄 Обновить", callback_data="dp:refresh")
            ],
            [
                InlineKeyboardButton(text="❓ Помощь", callback_data="dp:help")
            ]
        ])

        menu_text = (
            "🎮 **DPGame Reseller - Главное меню**\n\n"
            f"👤 **Пользователь:** {username}\n"
            f"💰 **Баланс:** ${balance}\n"
            f"🏪 **Реселлер:** {'✅ Да' if is_reseller else '❌ Нет'}\n"
            f"🔗 **Привязок:** {bindings_count} шт.\n\n"
            f"📈 **Статистика:**\n"
            f"• Заказов: {stats['total_orders']}\n"
            f"• Прибыль: {stats['total_profit']:.2f}₽\n\n"
            "Выберите действие:"
        )

        await message.answer(menu_text, reply_markup=keyboard, parse_mode="Markdown")

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в cmd_dp_game: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def handle_dp_callbacks(callback: types.CallbackQuery):
    """Обработчик callback кнопок меню"""
    global _reseller_instance

    if not _reseller_instance:
        await callback.answer("❌ Плагин не инициализирован")
        return

    action = callback.data.replace("dp:", "")

    try:
        if action == "refresh":
            # Обновляем баланс
            profile = await _reseller_instance.api.get_profile()

            if not profile:
                await callback.answer("❌ Не удалось обновить баланс", show_alert=True)
                return

            username = profile.get("username", "Неизвестно")
            balance = profile.get("balance", "0")
            is_reseller = profile.get("is_reseller", False)
            bindings_count = len(_reseller_instance.bindings)
            stats = _reseller_instance.get_stats()

            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [
                    InlineKeyboardButton(text="🔗 Добавить привязку", callback_data="dp:help_bind"),
                    InlineKeyboardButton(text="📋 Список привязок", callback_data="dp:list")
                ],
                [
                    InlineKeyboardButton(text="📝 Массовое добавление", callback_data="dp:help_mass"),
                    InlineKeyboardButton(text="📊 Статистика", callback_data="dp:stats")
                ],
                [
                    InlineKeyboardButton(text="⚙️ Настройки", callback_data="dp:settings"),
                    InlineKeyboardButton(text="🔄 Обновить", callback_data="dp:refresh")
                ],
                [
                    InlineKeyboardButton(text="❓ Помощь", callback_data="dp:help")
                ]
            ])

            menu_text = (
                "🎮 **DPGame Reseller - Главное меню**\n\n"
                f"👤 **Пользователь:** {username}\n"
                f"💰 **Баланс:** ${balance}\n"
                f"🏪 **Реселлер:** {'✅ Да' if is_reseller else '❌ Нет'}\n"
                f"🔗 **Привязок:** {bindings_count} шт.\n\n"
                f"📈 **Статистика:**\n"
                f"• Заказов: {stats['total_orders']}\n"
                f"• Прибыль: {stats['total_profit']:.2f}₽\n\n"
                "Выберите действие:"
            )

            await callback.message.edit_text(menu_text, reply_markup=keyboard, parse_mode="Markdown")
            await callback.answer("✅ Обновлено")

        elif action == "stats":
            stats = _reseller_instance.get_stats()

            stats_text = (
                "📊 **Статистика продаж**\n\n"
                f"📦 **Всего заказов:** {stats['total_orders']}\n"
                f"💵 **Продажи:** {stats['total_sales']:.2f}₽\n"
                f"💰 **Закупка:** {stats['total_costs']:.2f}₽\n"
                f"📈 **Прибыль:** {stats['total_profit']:.2f}₽\n"
                f"📊 **Средняя прибыль:** {stats['avg_profit']:.2f}₽\n\n"
                f"💡 **Маржа:** {(stats['total_profit'] / stats['total_sales'] * 100) if stats['total_sales'] > 0 else 0:.1f}%"
            )

            await callback.answer()
            await callback.message.answer(stats_text, parse_mode="Markdown")

        elif action == "settings":
            settings = _reseller_instance.settings

            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [
                    InlineKeyboardButton(
                        text=f"🧪 Тест-режим: {'✅ ВКЛ' if settings.get('test_mode') else '❌ ВЫКЛ'}",
                        callback_data="dp:toggle_test"
                    )
                ],
                [
                    InlineKeyboardButton(text="🔑 Изменить API ключ", callback_data="dp:setup_key")
                ],
                [
                    InlineKeyboardButton(text="🔙 Назад", callback_data="dp:refresh")
                ]
            ])

            settings_text = (
                "⚙️ **Настройки плагина**\n\n"
                f"🧪 **Тест-режим:** {'✅ Включен' if settings.get('test_mode') else '❌ Выключен'}\n"
                f"🔑 **API ключ:** {'✅ Настроен' if settings.get('api_key') else '❌ Не настроен'}\n"
                f"⏱ **Макс. время retry:** {settings.get('max_retry_minutes', 15)} мин\n"
                f"🔄 **Интервал retry:** {settings.get('retry_interval', 30)} сек\n"
                f"📅 **Проверка товаров:** каждые {settings.get('check_interval_hours', 2)} ч\n"
                f"💸 **Комиссия вывода:** {settings.get('withdrawal_fee_percent', 0)}%\n"
                f"🗂 **TTL кеша:** {settings.get('cache_ttl_minutes', 30)} мин\n\n"
                f"📁 **Файл настроек:** `{SETTINGS_FILE}`"
            )

            await callback.answer()
            await callback.message.answer(settings_text, reply_markup=keyboard, parse_mode="Markdown")

        elif action == "setup_key":
            # Активируем режим ввода API ключа
            user_id = callback.from_user.id
            _api_key_setup_states[user_id] = True

            await callback.answer()
            await callback.message.answer(
                "🔑 **Настройка API ключа DPGame**\n\n"
                "📝 Отправьте ваш API ключ следующим сообщением.\n\n"
                "**Где получить ключ:**\n"
                "1. Перейдите на https://wholesale.dpgame.shop/\n"
                "2. Войдите в аккаунт\n"
                "3. Профиль → API Keys → Create New Key\n"
                "4. Скопируйте ключ и отправьте сюда\n\n"
                "Для отмены отправьте `/dp_cancel`"
            )

        elif action == "toggle_test":
            # Переключаем тест-режим
            current_mode = _reseller_instance.settings.get("test_mode", False)
            _reseller_instance.settings["test_mode"] = not current_mode
            _reseller_instance.save_settings()

            new_mode = _reseller_instance.settings["test_mode"]
            mode_text = "включён ✅" if new_mode else "выключен ❌"

            await callback.answer(f"Тест-режим {mode_text}", show_alert=True)

            # Обновляем меню настроек
            settings = _reseller_instance.settings

            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [
                    InlineKeyboardButton(
                        text=f"🧪 Тест-режим: {'✅ ВКЛ' if settings.get('test_mode') else '❌ ВЫКЛ'}",
                        callback_data="dp:toggle_test"
                    )
                ],
                [
                    InlineKeyboardButton(text="🔑 Изменить API ключ", callback_data="dp:setup_key")
                ],
                [
                    InlineKeyboardButton(text="🔙 Назад", callback_data="dp:refresh")
                ]
            ])

            settings_text = (
                "⚙️ **Настройки плагина**\n\n"
                f"🧪 **Тест-режим:** {'✅ Включен' if settings.get('test_mode') else '❌ Выключен'}\n"
                f"🔑 **API ключ:** {'✅ Настроен' if settings.get('api_key') else '❌ Не настроен'}\n"
                f"⏱ **Макс. время retry:** {settings.get('max_retry_minutes', 15)} мин\n"
                f"🔄 **Интервал retry:** {settings.get('retry_interval', 30)} сек\n"
                f"📅 **Проверка товаров:** каждые {settings.get('check_interval_hours', 2)} ч\n"
                f"💸 **Комиссия вывода:** {settings.get('withdrawal_fee_percent', 0)}%\n"
                f"🗂 **TTL кеша:** {settings.get('cache_ttl_minutes', 30)} мин\n\n"
                f"📁 **Файл настроек:** `{SETTINGS_FILE}`"
            )

            await callback.message.edit_text(settings_text, reply_markup=keyboard, parse_mode="Markdown")

        elif action == "list":
            if not _reseller_instance.bindings:
                await callback.answer("📋 Привязок пока нет", show_alert=True)
                return

            bindings_text = []
            for starvell_id, dpgame_id in list(_reseller_instance.bindings.items())[:10]:
                bindings_text.append(f"• Starvell `{starvell_id}` → DPGame `{dpgame_id}`")

            if len(_reseller_instance.bindings) > 10:
                bindings_text.append(f"\n... и ещё {len(_reseller_instance.bindings) - 10} шт.")

            await callback.answer()
            await callback.message.answer(
                "📋 **Список привязок:**\n\n" + "\n".join(bindings_text) +
                f"\n\n**Всего:** {len(_reseller_instance.bindings)} шт."
            )

        elif action == "help_bind":
            await callback.answer()
            await callback.message.answer(
                "🔗 **Добавление одиночной привязки**\n\n"
                "**Команда:**\n"
                "`/dp_bind <dpgame_id> <starvell_offer>`\n\n"
                "**Примеры:**\n"
                "`/dp_bind 123 207715`\n"
                "`/dp_bind 123 https://starvell.com/offers/207715`"
            )

        elif action == "help_mass":
            await callback.answer()
            await callback.message.answer(
                "📝 **Массовое добавление привязок**\n\n"
                "1. Отправьте команду `/dp_any`\n"
                "2. Отправляйте строки в формате:\n"
                "   `<dpgame_id> <starvell_offer_id>`\n\n"
                "**Пример:**\n"
                "`123 207715`\n"
                "`456 207716`\n\n"
                "3. Для завершения: `/dp_stop`"
            )

        elif action == "help":
            await callback.answer()
            await callback.message.answer(
                "❓ **Справка по командам**\n\n"
                "`/dp_game` - Главное меню\n"
                "`/dp_bind` - Добавить привязку\n"
                "`/dp_any` - Массовое добавление\n"
                "`/dp_stop` - Остановить массовое добавление\n"
                "`/dp_unbind` - Удалить привязку\n"
                "`/dp_list` - Список привязок\n"
                "`/dp_balance` - Баланс DPGame\n\n"
                "**Особенности:**\n"
                "• Автоматическая покупка с DPGame\n"
                "• Retry логика (15 минут)\n"
                "• Статистика продаж\n"
                "• Тест-режим\n"
                "• Периодическая проверка товаров\n"
                "• Настраиваемые шаблоны сообщений"
            )

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в handle_dp_callbacks: {e}", exc_info=True)
        await callback.answer(f"❌ Ошибка: {str(e)}", show_alert=True)


async def cmd_dp_unbind(message: types.Message):
    """Команда для удаления привязки
    Использование: /dp_unbind <starvell_offer_id>
    """
    global _reseller_instance

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    try:
        args = message.text.split()[1:]

        if len(args) != 1:
            await message.answer(
                "❌ **Неверный формат команды**\n\n"
                "📝 **Использование:**\n"
                "`/dp_unbind <starvell_offer_id>`\n\n"
                "**Пример:**\n"
                "`/dp_unbind 207715`"
            )
            return

        starvell_offer_id = args[0]

        if str(starvell_offer_id) not in _reseller_instance.bindings:
            await message.answer(f"❌ Привязка для лота `{starvell_offer_id}` не найдена", parse_mode="Markdown")
            return

        dpgame_position_id = _reseller_instance.bindings[str(starvell_offer_id)]
        del _reseller_instance.bindings[str(starvell_offer_id)]
        _reseller_instance.save_bindings()

        await message.answer(
            "✅ **Привязка удалена**\n\n"
            f"🔗 **Starvell Offer ID:** `{starvell_offer_id}`\n"
            f"🎮 **DPGame Position ID:** `{dpgame_position_id}`"
        )

        logger.info(f"{LOGGER_PREFIX} Удалена привязка: Starvell {starvell_offer_id}")

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в cmd_dp_unbind: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def cmd_dp_list(message: types.Message):
    """Команда для просмотра всех привязок"""
    global _reseller_instance

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    try:
        if not _reseller_instance.bindings:
            await message.answer("📋 **Привязок пока нет**\n\nИспользуйте `/dp_bind` или `/dp_any` для создания", parse_mode="Markdown")
            return

        bindings_text = []
        for starvell_id, dpgame_id in _reseller_instance.bindings.items():
            bindings_text.append(f"• Starvell `{starvell_id}` → DPGame `{dpgame_id}`")

        await message.answer(
            "📋 **Список привязок:**\n\n" + "\n".join(bindings_text) +
            f"\n\n**Всего:** {len(_reseller_instance.bindings)} шт."
        )

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в cmd_dp_list: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


async def cmd_dp_balance(message: types.Message):
    """Команда для проверки баланса DPGame"""
    global _reseller_instance

    if not _reseller_instance:
        await message.answer("❌ Плагин не инициализирован", parse_mode="Markdown")
        return

    try:
        profile = await _reseller_instance.api.get_profile()

        if not profile:
            await message.answer("❌ Не удалось получить данные профиля DPGame", parse_mode="Markdown")
            return

        username = profile.get("username", "Неизвестно")
        balance = profile.get("balance", "0")
        is_reseller = profile.get("is_reseller", False)

        await message.answer(
            "💰 **Баланс DPGame**\n\n"
            f"👤 **Пользователь:** {username}\n"
            f"💵 **Баланс:** ${balance}\n"
            f"🏪 **Реселлер:** {'✅ Да' if is_reseller else '❌ Нет'}"
        )

    except Exception as e:
        logger.error(f"{LOGGER_PREFIX} Ошибка в cmd_dp_balance: {e}", exc_info=True)
        await message.answer(f"❌ Ошибка: {str(e)}", parse_mode="Markdown")


